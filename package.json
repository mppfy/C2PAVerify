{
  "name": "@mppfy/c2pa-verify",
  "version": "0.1.0",
  "private": true,
  "description": "MPP-compatible service for verifying C2PA content provenance manifests.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 migrations apply c2pa-verify --local",
    "db:migrate:staging": "wrangler d1 migrations apply c2pa-verify --remote --env staging"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "mppx": "latest",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.0.0"
  }
}
